# VYRON — Environment Variables
#
# Nothing here is required. With every value unset (or blank), the app runs
# fully offline: a fixed demo identity, seeded in-memory data, and a
# heuristic goal planner. Set any of these to switch that piece to the real
# thing — no code changes needed.

# Database (Neon / any Postgres). Unset -> serves seeded mock data.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"


# Auth (Clerk). Unset -> fixed demo user, no ClerkProvider mounted.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# AI model (Vercel AI SDK, OpenAI-compatible). Unset -> local heuristic planner.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Escrow settlement provider: "simulated" (default) or "xlayer".
#
# lib/escrow/xlayer-provider.ts is a real implementation (viem, real
# transactions, waits for confirmation) — it's just not switched on by
# default because it needs contracts deployed first. To go live:
#   1. cd contracts && npm install
#   2. Put a funded X Layer Testnet wallet's key in contracts/.env as
#      DEPLOYER_PRIVATE_KEY (see contracts/.env.example) — never this file.
#   3. npm run deploy:xlayer-testnet
#   4. Copy the three addresses it prints into the vars below.
#   5. Set ORCHESTRATOR_PRIVATE_KEY to that same (or another funded) wallet's
#      key — this is the server-side wallet that actually calls the
#      contracts on VYRON's behalf. Keep it out of every other file.
#   6. Set ESCROW_PROVIDER="xlayer".
ESCROW_PROVIDER="simulated"
ORCHESTRATOR_PRIVATE_KEY=""
ESCROW_CONTRACT_ADDRESS=""
AGENT_REGISTRY_CONTRACT_ADDRESS=""
REPUTATION_CONTRACT_ADDRESS=""

# Overrides viem's built-in X Layer Testnet RPC, which doesn't resolve from
# some networks (confirmed in this environment) — testrpc.xlayer.tech is
# used by default and resolves to the same chain (1952).
NEXT_PUBLIC_XLAYER_RPC_URL=""

# WalletConnect Cloud project id (cloud.reown.com) — powers the WalletConnect
# connector. Unset -> that connector is simply omitted; OKX Wallet and
# MetaMask still work via their injected/SDK connectors with zero config.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""