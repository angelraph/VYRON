# Deployment credentials for X Layer Testnet — NEVER commit the real .env
# file (it's gitignored). This wallet only needs to hold enough testnet OKB
# to pay gas for the three contract deployments plus a few setup calls.
DEPLOYER_PRIVATE_KEY=""

# Optional override — defaults to https://testrpc.xlayer.tech in
# hardhat.config.ts (chainId 1952).
XLAYER_TESTNET_RPC_URL=""
